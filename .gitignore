# Dependency directories
node_modules/
jspm_packages/
frontend/node_modules/
backend/node_modules/

# Build and distribution directories
dist/
build/
.out/

# Local Multi-User Storage & Operational Analytics Files (NEVER push to GitHub)
backend/data/users.json
backend/data/feedback.json
backend/data/unanswered.json

# Optional exception: Keep the core static FAQ knowledge base checked in
!backend/data/faq.json

# Environment configurations and hidden secret credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs generated by NPM/Yarn errors
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# System specific tracking files (OS X / Windows caches)
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE files (VS Code / WebStorm system setups)
.vscode/
